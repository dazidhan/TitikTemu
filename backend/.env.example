# =========================================================================
# Backend Environment Variables Template (Local Running)
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# Port configuration
PORT=5000
NODE_ENV=development

# Database connection URL
# Replace credentials and localhost/port if using external MongoDB
MONGO_URI=mongodb://your_db_username:your_db_password@localhost:27017/your_database_name?authSource=admin

# JWT secret key
JWT_SECRET=your_jwt_secret_key_change_in_production

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# Midtrans API Credentials
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
