# =========================================================================
# Root Environment Variables Template for Docker Compose
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# MongoDB Root Configuration
MONGO_INITDB_ROOT_USERNAME=your_db_username
MONGO_INITDB_ROOT_PASSWORD=your_db_password
MONGO_INITDB_DATABASE=your_database_name

# JSON Web Token (JWT) Configuration
# You can generate a secure random secret using: node -e "R=require('crypto');console.log(R.randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production

# Midtrans Payment Gateway API Credentials
# Get these from your Midtrans Sandbox/Production Dashboard (Settings -> Access Keys)
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
