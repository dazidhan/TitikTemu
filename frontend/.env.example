# =========================================================================
# Frontend Environment Variables Template (Local Running)
# Copy this file to '.env.local' and fill in your actual configurations.
# =========================================================================

# API URL endpoint for Next.js (usually backend URL)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Midtrans Client Key (Safe to expose to frontend, prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
